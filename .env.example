# --- Application Configuration ---
PORT=3000
NODE_ENV=development

# --- Database Integration ---
# When running locally using npm, use localhost. When using docker-compose, use 'mongo'
MONGODB_URI=mongodb://localhost:27017/water-meter

# --- Security & Authentication ---
# VERY IMPORTANT: In production, generate a strong random 256-bit hash for JWT_SECRET
JWT_SECRET=your_jwt_secret_here
# Can be set in days (7d) or hours (24h)
JWT_EXPIRE=7d

# --- File Storage ---
# Relative or absolute path defining where incoming meter photos reside
UPLOAD_PATH=./uploads
