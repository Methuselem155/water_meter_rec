# --- Application Configuration ---
PORT=3000
NODE_ENV=development

# --- Database Integration ---
# REQUIRED. When running locally use localhost. When using docker-compose use 'mongo'.
MONGODB_URI=mongodb://localhost:27017/water-meter

# --- Security & Authentication ---
# REQUIRED. Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret
# Token expiry: days (7d) or hours (24h)
JWT_EXPIRE=7d

# --- CORS ---
# Comma-separated list of allowed origins. Leave empty to allow all (dev only).
# Example: ALLOWED_ORIGINS=https://myapp.com,https://admin.myapp.com
ALLOWED_ORIGINS=

# --- File Storage ---
UPLOAD_PATH=./uploads

# --- Cloudinary (image storage) ---
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Python OCR ---
# Override the python command (default: python3 on Linux/Mac, python on Windows)
# PYTHON_OCR_CMD=python3

# Port for the persistent Python OCR server (python_ocr_server.py)
# Start it once with: python python_ocr_server.py
# The Node server will call it via HTTP — much faster than spawning a new process per request.
OCR_SERVER_PORT=5001
