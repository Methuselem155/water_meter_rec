* text=auto

# Force LF for these files (Unix-style)
*.md text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.py text eol=lf
*.txt text eol=lf
.gitignore text eol=lf
.env text eol=lf
Dockerfile text eol=lf

# Dart/Flutter files
*.dart text eol=lf
pubspec.yaml text eol=lf
pubspec.lock text eol=lf
.metadata text eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.lock binary
*.jar binary
